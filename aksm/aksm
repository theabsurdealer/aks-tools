#!/usr/bin/env bash
# aksm — AKS Manager: check pod status, view logs, manage configmaps.
# Same picker flow as aksc. No global "az account set".

set -euo pipefail

need() { command -v "$1" >/dev/null 2>&1 || { echo "Missing dependency: $1" >&2; exit 1; }; }
need kubectl
need az

KUBECTL="kubectl"
KUBE_CTX=""

die() { echo "Error: $*" >&2; exit 1; }
has_fzf() { command -v fzf >/dev/null 2>&1; }

# -------- Pickers (same as aksc) --------

pick_subscription() {
  echo "Fetching Azure subscriptions..." >&2
  local ids=() names=()
  while IFS=$'\t' read -r id name; do
    [[ -n "$id" ]] || continue
    ids+=("$id"); names+=("$name")
  done <<EOF
$(az account list --query "[].{id:id, name:name}" -o tsv 2>/dev/null || true)
EOF
  ((${#ids[@]})) || die "No Azure subscriptions found. Run: az login"
  if ((${#ids[@]}==1)); then echo "${ids[0]}"; return; fi
  if has_fzf; then
    local selected
    selected="$(for i in "${!ids[@]}"; do printf "%s\t%s\n" "${names[$i]}" "${ids[$i]}"; done \
      | fzf --with-nth=1 --delimiter=$'\t' --prompt="Azure subscription > " --height=40% --reverse)"
    [[ -n "$selected" ]] || exit 1
    echo "$selected" | awk -F'\t' '{print $2}'
  else
    echo "Select Azure subscription:" >&2
    for i in "${!ids[@]}"; do printf "%2d) %s (%s)\n" "$((i+1))" "${names[$i]}" "${ids[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#ids[@]} )) && { echo "${ids[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

pick_aks_cluster() {
  local sub_id="$1"
  echo "Fetching AKS clusters..." >&2
  local c_names=() c_rgs=()
  while IFS=$'\t' read -r name rg; do
    [[ -n "$name" ]] || continue
    c_names+=("$name"); c_rgs+=("$rg")
  done <<EOF
$(az aks list --subscription "$sub_id" --query "[].{name:name, rg:resourceGroup}" -o tsv 2>/dev/null || true)
EOF
  ((${#c_names[@]})) || die "No AKS clusters found in this subscription."
  if ((${#c_names[@]}==1)); then echo "${c_names[0]}|${c_rgs[0]}"; return; fi
  if has_fzf; then
    local selected
    selected="$(for i in "${!c_names[@]}"; do printf "%s\t%s\n" "${c_names[$i]}" "${c_rgs[$i]}"; done \
      | fzf --with-nth=1 --delimiter=$'\t' --prompt="AKS cluster > " --height=40% --reverse)"
    [[ -n "$selected" ]] || exit 1
    echo "$(echo "$selected" | awk -F'\t' '{print $1}')|$(echo "$selected" | awk -F'\t' '{print $2}')"
  else
    echo "Select AKS cluster:" >&2
    for i in "${!c_names[@]}"; do printf "%2d) %s (RG: %s)\n" "$((i+1))" "${c_names[$i]}" "${c_rgs[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#c_names[@]} )) && { echo "${c_names[$((n-1))]}|${c_rgs[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

list_ns() { $KUBECTL --context "$KUBE_CTX" get ns -o custom-columns=NAME:.metadata.name --no-headers; }

pick_ns() {
  if has_fzf; then
    list_ns | fzf --prompt="Namespace > " --height=40% --reverse
  else
    local items=()
    while IFS= read -r line; do [[ -n "$line" ]] && items+=("$line"); done <<EOF
$(list_ns)
EOF
    ((${#items[@]})) || die "No namespaces found."
    echo "Select a namespace:" >&2
    for i in "${!items[@]}"; do printf "%2d) %s\n" "$((i+1))" "${items[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#items[@]} )) && { echo "${items[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

pick_pod() {
  local ns="$1"
  local pods=()
  while IFS= read -r line; do [[ -n "$line" ]] && pods+=("$line"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get pods -o custom-columns=NAME:.metadata.name,STATUS:.status.phase,RESTARTS:.status.containerStatuses[0].restartCount,AGE:.metadata.creationTimestamp --no-headers 2>/dev/null || true)
EOF
  ((${#pods[@]})) || die "No pods found in $ns"
  if has_fzf; then
    printf "%s\n" "${pods[@]}" | fzf --prompt="Pod > " --height=40% --reverse | awk '{print $1}'
  else
    echo "Select a pod:" >&2
    for i in "${!pods[@]}"; do printf "%2d) %s\n" "$((i+1))" "${pods[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#pods[@]} )) && { echo "${pods[$((n-1))]}" | awk '{print $1}'; return; }
      echo "Invalid selection." >&2
    done
  fi
}

pick_configmap() {
  local ns="$1"
  local cms=()
  while IFS= read -r line; do [[ -n "$line" ]] && cms+=("$line"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get cm -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null | grep -v kube-root-ca || true)
EOF
  ((${#cms[@]})) || die "No configmaps found in $ns"
  if ((${#cms[@]}==1)); then echo "${cms[0]}"; return; fi
  if has_fzf; then
    printf "%s\n" "${cms[@]}" | fzf --prompt="ConfigMap > " --height=40% --reverse
  else
    echo "Select a ConfigMap:" >&2
    for i in "${!cms[@]}"; do printf "%2d) %s\n" "$((i+1))" "${cms[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#cms[@]} )) && { echo "${cms[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

# -------- Commands --------

cmd_pods() {
  local ns="$1"
  echo
  echo "=== Pods in $ns ==="
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get pods -o wide
}

cmd_logs() {
  local ns="$1"
  local pod
  pod="$(pick_pod "$ns")"
  local tail="${2:-100}"
  echo
  echo "=== Logs for $pod (tail $tail) ==="
  $KUBECTL --context "$KUBE_CTX" -n "$ns" logs "$pod" --tail="$tail" --all-containers=true
}

cmd_logs_follow() {
  local ns="$1"
  local pod
  pod="$(pick_pod "$ns")"
  echo
  echo "=== Following logs for $pod (Ctrl+C to stop) ==="
  $KUBECTL --context "$KUBE_CTX" -n "$ns" logs "$pod" -f --all-containers=true
}

cmd_describe() {
  local ns="$1"
  local pod
  pod="$(pick_pod "$ns")"
  echo
  $KUBECTL --context "$KUBE_CTX" -n "$ns" describe pod "$pod"
}

cmd_events() {
  local ns="$1"
  echo
  echo "=== Recent events in $ns ==="
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get events --sort-by=.lastTimestamp | tail -30
}

cmd_configmap_view() {
  local ns="$1"
  local cm
  cm="$(pick_configmap "$ns")"
  echo
  echo "=== ConfigMap: $cm ==="
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o yaml
}

cmd_configmap_get() {
  local ns="$1"
  local cm
  cm="$(pick_configmap "$ns")"
  echo
  echo "=== ConfigMap: $cm (data only) ==="
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o jsonpath='{.data}' | python3 -m json.tool 2>/dev/null || \
    $KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o jsonpath='{.data}'
  echo
}

cmd_configmap_set() {
  local ns="$1"
  local cm
  cm="$(pick_configmap "$ns")"

  echo "Set configmap values (KEY=VALUE). Empty line to finish."
  local patch_data="{"
  local first=1
  while true; do
    read -rp "  KEY=VALUE> " kv
    [[ -z "$kv" ]] && break
    if [[ "$kv" != *"="* ]]; then
      echo "  Invalid format. Use KEY=VALUE" >&2
      continue
    fi
    local key="${kv%%=*}"
    local val="${kv#*=}"
    if [[ $first -eq 1 ]]; then
      first=0
    else
      patch_data+=","
    fi
    # Escape quotes in value
    val="${val//\"/\\\"}"
    patch_data+="\"$key\":\"$val\""
  done
  patch_data+="}"

  if [[ "$patch_data" == "{}" ]]; then
    echo "No values provided, skipping." >&2
    return
  fi

  echo
  echo "Patching $cm with: $patch_data"
  read -rp "Confirm? (y/n) > " confirm
  if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
    $KUBECTL --context "$KUBE_CTX" -n "$ns" patch configmap "$cm" --type merge -p "{\"data\":$patch_data}"
    echo "Done. Run 'aksm restart' to apply changes."
  else
    echo "Cancelled."
  fi
}

cmd_configmap_delete_key() {
  local ns="$1"
  local cm
  cm="$(pick_configmap "$ns")"

  # Show current keys
  echo "Current keys in $cm:"
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o jsonpath='{range .data}{@}{"\n"}{end}' 2>/dev/null || true
  local keys=()
  while IFS= read -r k; do [[ -n "$k" ]] && keys+=("$k"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o jsonpath='{keys(.data)}' 2>/dev/null | tr '[]' '\n' | tr ' ' '\n' | sed '/^$/d')
EOF

  if has_fzf; then
    local key
    key="$(printf "%s\n" "${keys[@]}" | fzf --prompt="Key to delete > " --height=40% --reverse)"
    [[ -n "$key" ]] || return
    read -rp "Delete key '$key' from $cm? (y/n) > " confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
      $KUBECTL --context "$KUBE_CTX" -n "$ns" patch configmap "$cm" --type json -p "[{\"op\":\"remove\",\"path\":\"/data/$key\"}]"
      echo "Deleted '$key'. Run 'aksm restart' to apply."
    fi
  else
    echo "Keys:" >&2
    for i in "${!keys[@]}"; do printf "%2d) %s\n" "$((i+1))" "${keys[$i]}" >&2; done
    read -rp "Key number to delete > " n
    if [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#keys[@]} )); then
      local key="${keys[$((n-1))]}"
      read -rp "Delete key '$key' from $cm? (y/n) > " confirm
      if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
        $KUBECTL --context "$KUBE_CTX" -n "$ns" patch configmap "$cm" --type json -p "[{\"op\":\"remove\",\"path\":\"/data/$key\"}]"
        echo "Deleted '$key'. Run 'aksm restart' to apply."
      fi
    fi
  fi
}

cmd_restart() {
  local ns="$1"
  local deploys=()
  while IFS= read -r d; do [[ -n "$d" ]] && deploys+=("$d"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get deploy -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null || true)
EOF
  ((${#deploys[@]})) || die "No deployments found in $ns"

  local deploy
  if ((${#deploys[@]}==1)); then
    deploy="${deploys[0]}"
  elif has_fzf; then
    deploy="$(printf "%s\n" "${deploys[@]}" | fzf --prompt="Deployment to restart > " --height=40% --reverse)"
  else
    echo "Select deployment:" >&2
    for i in "${!deploys[@]}"; do printf "%2d) %s\n" "$((i+1))" "${deploys[$i]}" >&2; done
    read -rp "> " n
    [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#deploys[@]} )) && deploy="${deploys[$((n-1))]}"
  fi

  [[ -n "${deploy:-}" ]] || die "No deployment selected."
  echo "Restarting deployment $deploy..."
  $KUBECTL --context "$KUBE_CTX" -n "$ns" rollout restart deployment "$deploy"
  echo "Watching rollout..."
  $KUBECTL --context "$KUBE_CTX" -n "$ns" rollout status deployment "$deploy" --timeout=120s || true
}

# -------- Action picker --------

pick_action() {
  local actions=(
    "pods        — List all pods"
    "logs        — View pod logs"
    "logs-follow — Follow pod logs (live)"
    "describe    — Describe a pod"
    "events      — Recent namespace events"
    "cm-view     — View configmap (full yaml)"
    "cm-get      — View configmap data (key/values)"
    "cm-set      — Add/update configmap values"
    "cm-del      — Delete a configmap key"
    "restart     — Restart a deployment"
    "quit        — Exit"
  )

  if has_fzf; then
    printf "%s\n" "${actions[@]}" | fzf --prompt="Action > " --height=40% --reverse | awk '{print $1}'
  else
    echo "Select action:" >&2
    for i in "${!actions[@]}"; do printf "%2d) %s\n" "$((i+1))" "${actions[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#actions[@]} )) && { echo "${actions[$((n-1))]}" | awk '{print $1}'; return; }
      echo "Invalid selection." >&2
    done
  fi
}

# -------- Help --------

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<HELP
Usage: aksm [COMMAND]

AKS Manager - Manage pods, logs, and configmaps interactively.

COMMANDS (optional, interactive menu if omitted):
  pods         List all pods in the namespace
  logs         View pod logs (pick a pod)
  logs-follow  Follow pod logs live
  describe     Describe a pod
  events       Recent namespace events
  cm-view      View configmap (full yaml)
  cm-get       View configmap data (key/values only)
  cm-set       Add or update configmap values
  cm-del       Delete a configmap key
  restart      Restart a deployment (rollout restart)
  -h, --help   Show this help

EXAMPLES:
  aksm                # Interactive — pick sub, cluster, namespace, then action menu
  aksm pods           # Jump straight to pod listing after picking namespace
  aksm cm-set         # Jump straight to configmap editing
  aksm restart        # Restart a deployment

HELP
  exit 0
fi

# -------- Main flow --------

az account show >/dev/null 2>&1 || die "Not logged into Azure CLI. Run: az login"

SUB_ID="$(pick_subscription)"
CLUSTER_INFO="$(pick_aks_cluster "$SUB_ID")"
CLUSTER_NAME="${CLUSTER_INFO%%|*}"
CLUSTER_RG="${CLUSTER_INFO##*|}"
KUBE_CTX="aksc-${SUB_ID:0:8}-${CLUSTER_NAME}"

echo "Getting AKS credentials for $CLUSTER_NAME..." >&2
az aks get-credentials \
  --subscription "$SUB_ID" \
  --resource-group "$CLUSTER_RG" \
  --name "$CLUSTER_NAME" \
  --overwrite-existing \
  --context "$KUBE_CTX" 2>/dev/null || die "Failed to get AKS credentials."

NAMESPACE="$(pick_ns)"

echo
echo "Context:   $KUBE_CTX"
echo "Namespace: $NAMESPACE"
echo

# If command passed as argument, run it directly
if [[ -n "${1:-}" ]]; then
  ACTION="$1"
else
  # Interactive action loop
  while true; do
    ACTION="$(pick_action)"
    case "$ACTION" in
      pods)        cmd_pods "$NAMESPACE" ;;
      logs)        cmd_logs "$NAMESPACE" ;;
      logs-follow) cmd_logs_follow "$NAMESPACE" ;;
      describe)    cmd_describe "$NAMESPACE" ;;
      events)      cmd_events "$NAMESPACE" ;;
      cm-view)     cmd_configmap_view "$NAMESPACE" ;;
      cm-get)      cmd_configmap_get "$NAMESPACE" ;;
      cm-set)      cmd_configmap_set "$NAMESPACE" ;;
      cm-del)      cmd_configmap_delete_key "$NAMESPACE" ;;
      restart)     cmd_restart "$NAMESPACE" ;;
      quit)        echo "Bye!"; exit 0 ;;
      *)           echo "Unknown action: $ACTION" >&2 ;;
    esac
    echo
  done
fi

# Single command mode
case "$ACTION" in
  pods)        cmd_pods "$NAMESPACE" ;;
  logs)        cmd_logs "$NAMESPACE" ;;
  logs-follow) cmd_logs_follow "$NAMESPACE" ;;
  describe)    cmd_describe "$NAMESPACE" ;;
  events)      cmd_events "$NAMESPACE" ;;
  cm-view)     cmd_configmap_view "$NAMESPACE" ;;
  cm-get)      cmd_configmap_get "$NAMESPACE" ;;
  cm-set)      cmd_configmap_set "$NAMESPACE" ;;
  cm-del)      cmd_configmap_delete_key "$NAMESPACE" ;;
  restart)     cmd_restart "$NAMESPACE" ;;
  *)           die "Unknown command: $ACTION. Run aksm --help" ;;
esac
