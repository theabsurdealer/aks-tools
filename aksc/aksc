#!/usr/bin/env bash
# aksc — pick Azure subscription -> AKS cluster -> namespace, run Rails console pod, auto-cleanup.
# No global "az account set". Uses --subscription per call.
# Unique kube context per cluster+subscription so dev/stg/prod don't overwrite each other.
# Optional: KEEP_POD=1 aksc  (keeps pod on failure)

set -euo pipefail

need() { command -v "$1" >/dev/null 2>&1 || { echo "Missing dependency: $1" >&2; exit 1; }; }
need kubectl
need az
need python3

KUBECTL="kubectl"
KEEP_POD="${KEEP_POD:-0}"
ATTACH_MODE="${AKSC_ATTACH_MODE:-attach}"
SUCCESS=0

# Safe defaults for trap under set -u
NAMESPACE=""
POD=""
KUBE_CTX=""

die() { echo "Error: $*" >&2; exit 1; }
has_fzf() { command -v fzf >/dev/null 2>&1; }

list_orphaned_pods() {
  local user_name="${1:-$(id -un 2>/dev/null || whoami)}"
  local pattern="rails-console-${user_name}-"

  echo "Searching for orphaned Rails console pods created by: $user_name" >&2
  echo >&2

  # Get all contexts
  local contexts=()
  while IFS= read -r ctx; do
    [[ -n "$ctx" ]] && contexts+=("$ctx")
  done < <(kubectl config get-contexts -o name 2>/dev/null | grep -E '^aksc-' || true)

  if ((${#contexts[@]} == 0)); then
    echo "No aksc contexts found. Run aksc normally first to create contexts." >&2
    return 0
  fi

  local found=0
  for ctx in "${contexts[@]}"; do
    # Get all namespaces in this context
    local namespaces=()
    while IFS= read -r ns; do
      [[ -n "$ns" ]] && namespaces+=("$ns")
    done < <(kubectl --context "$ctx" get ns -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null || true)

    for ns in "${namespaces[@]}"; do
      # Find matching pods
      local pods_info
      pods_info=$(kubectl --context "$ctx" -n "$ns" get pods \
        --field-selector metadata.name!="" \
        -o custom-columns=NAME:.metadata.name,STATUS:.status.phase,AGE:.metadata.creationTimestamp \
        --no-headers 2>/dev/null | grep "^$pattern" || true)

      if [[ -n "$pods_info" ]]; then
        if [[ $found -eq 0 ]]; then
          printf "%-50s %-20s %-15s %-30s\n" "CONTEXT" "NAMESPACE" "STATUS" "POD"
          printf "%s\n" "$(printf '=%.0s' {1..115})"
          found=1
        fi

        while IFS= read -r line; do
          [[ -z "$line" ]] && continue
          local pod_name=$(echo "$line" | awk '{print $1}')
          local status=$(echo "$line" | awk '{print $2}')
          local created=$(echo "$line" | awk '{print $3}')

          # Calculate age
          local age="N/A"
          if [[ -n "$created" ]]; then
            age=$(kubectl --context "$ctx" -n "$ns" get pod "$pod_name" -o jsonpath='{.metadata.creationTimestamp}' 2>/dev/null | xargs -I {} date -j -f "%Y-%m-%dT%H:%M:%SZ" {} "+%s" 2>/dev/null || echo "")
            if [[ -n "$age" ]]; then
              local now=$(date +%s)
              local diff=$((now - age))
              local hours=$((diff / 3600))
              local mins=$(((diff % 3600) / 60))
              if [[ $hours -gt 0 ]]; then
                age="${hours}h${mins}m"
              else
                age="${mins}m"
              fi
            else
              age="N/A"
            fi
          fi

          printf "%-50s %-20s %-15s %-30s (age: %s)\n" "$ctx" "$ns" "$status" "$pod_name" "$age"
        done <<< "$pods_info"
      fi
    done
  done

  if [[ $found -eq 0 ]]; then
    echo "No orphaned Rails console pods found for user: $user_name" >&2
  else
    echo >&2
    echo "To delete a specific pod: kubectl --context <CONTEXT> -n <NAMESPACE> delete pod <POD>" >&2
    echo "To delete all your orphaned pods, run: aksc --cleanup-all" >&2
  fi
}

cleanup_all_orphaned() {
  local user_name="${1:-$(id -un 2>/dev/null || whoami)}"
  local pattern="rails-console-${user_name}-"

  echo "Cleaning up all orphaned Rails console pods for: $user_name" >&2

  # Get all contexts
  local contexts=()
  while IFS= read -r ctx; do
    [[ -n "$ctx" ]] && contexts+=("$ctx")
  done < <(kubectl config get-contexts -o name 2>/dev/null | grep -E '^aksc-' || true)

  if ((${#contexts[@]} == 0)); then
    echo "No aksc contexts found." >&2
    return 0
  fi

  local deleted=0
  for ctx in "${contexts[@]}"; do
    local namespaces=()
    while IFS= read -r ns; do
      [[ -n "$ns" ]] && namespaces+=("$ns")
    done < <(kubectl --context "$ctx" get ns -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null || true)

    for ns in "${namespaces[@]}"; do
      local pods
      pods=$(kubectl --context "$ctx" -n "$ns" get pods \
        -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null \
        | grep "^$pattern" || true)

      while IFS= read -r pod; do
        [[ -z "$pod" ]] && continue
        echo "Deleting: $pod (context: $ctx, namespace: $ns)" >&2
        kubectl --context "$ctx" -n "$ns" delete pod "$pod" --wait=false >/dev/null 2>&1 || echo "  Failed to delete $pod" >&2
        ((deleted++))
      done <<< "$pods"
    done
  done

  if [[ $deleted -eq 0 ]]; then
    echo "No orphaned pods found to clean up." >&2
  else
    echo "Deleted $deleted orphaned pod(s)." >&2
  fi
}

cleanup() {
  [[ -n "${NAMESPACE}" && -n "${POD}" ]] || return 0

  if [[ "$SUCCESS" -ne 0 && "$KEEP_POD" -eq 1 ]]; then
    echo
    echo "KEEP_POD=1 set, not deleting failed pod: $POD"
    return 0
  fi

  echo
  echo "Cleaning up pod $POD ..."
  $KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" delete pod "$POD" --wait=false >/dev/null 2>&1 || true
}
trap cleanup EXIT

print_pod_debug() {
  local ns="$1"
  local pod="$2"

  echo
  echo "==================== POD DEBUG ===================="
  echo "Context:   $KUBE_CTX"
  echo "Namespace: $ns"
  echo "Pod:       $pod"
  echo "---------------------------------------------------"
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get pod "$pod" -o wide || true

  echo
  echo "---- describe (includes Events at bottom) ----"
  $KUBECTL --context "$KUBE_CTX" -n "$ns" describe pod "$pod" || true

  echo
  echo "---- recent events (namespace) ----"
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get events --sort-by=.lastTimestamp | tail -n 40 || true

  echo
  echo "---- logs (all containers) ----"
  local pod_json
  pod_json="$($KUBECTL --context "$KUBE_CTX" -n "$ns" get pod "$pod" -o json 2>/dev/null || true)"
  [[ -n "$pod_json" ]] || { echo "Could not fetch pod JSON for logs." >&2; return 0; }

  local containers
  containers="$(printf '%s' "$pod_json" | python3 - <<'PY'
import sys, json
d=json.load(sys.stdin)
names=[]
for c in (d.get("spec", {}).get("initContainers") or []):
  if c.get("name"): names.append(c["name"])
for c in (d.get("spec", {}).get("containers") or []):
  if c.get("name"): names.append(c["name"])
print("\n".join(names))
PY
)"
  while IFS= read -r cname; do
    [[ -n "$cname" ]] || continue
    echo
    echo ">>> container: $cname (current) [tail 200]"
    $KUBECTL --context "$KUBE_CTX" -n "$ns" logs "$pod" -c "$cname" --tail=200 2>/dev/null || true
    echo
    echo ">>> container: $cname (previous) [tail 200]"
    $KUBECTL --context "$KUBE_CTX" -n "$ns" logs "$pod" -c "$cname" --previous --tail=200 2>/dev/null || true
  done <<EOF
$containers
EOF

  echo "==================================================="
}

pick_subscription() {
  echo "Fetching Azure subscriptions..." >&2

  local ids=()
  local names=()

  while IFS=$'\t' read -r id name; do
    [[ -n "$id" ]] || continue
    ids+=("$id")
    names+=("$name")
  done <<EOF
$(az account list --query "[].{id:id, name:name}" -o tsv 2>/dev/null || true)
EOF

  ((${#ids[@]})) || die "No Azure subscriptions found. Run: az login"

  if ((${#ids[@]}==1)); then
    echo "${ids[0]}"; return
  fi

  if has_fzf; then
    local selected
    selected="$(for i in "${!ids[@]}"; do printf "%s\t%s\n" "${names[$i]}" "${ids[$i]}"; done \
      | fzf --with-nth=1 --delimiter=$'\t' --prompt="Azure subscription > " --height=40% --reverse)"
    [[ -n "$selected" ]] || exit 1
    echo "$selected" | awk -F'\t' '{print $2}'
  else
    echo "Select Azure subscription:" >&2
    for i in "${!ids[@]}"; do printf "%2d) %s (%s)\n" "$((i+1))" "${names[$i]}" "${ids[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#ids[@]} )) && { echo "${ids[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

pick_aks_cluster() {
  local sub_id="$1"
  echo "Fetching AKS clusters in subscription..." >&2

  local c_names=()
  local c_rgs=()

  while IFS=$'\t' read -r name rg; do
    [[ -n "$name" ]] || continue
    c_names+=("$name")
    c_rgs+=("$rg")
  done <<EOF
$(az aks list --subscription "$sub_id" --query "[].{name:name, rg:resourceGroup}" -o tsv 2>/dev/null || true)
EOF

  ((${#c_names[@]})) || die "No AKS clusters found (or no access) in this subscription."

  if ((${#c_names[@]}==1)); then
    echo "${c_names[0]}|${c_rgs[0]}"; return
  fi

  if has_fzf; then
    local selected
    selected="$(for i in "${!c_names[@]}"; do printf "%s\t%s\n" "${c_names[$i]}" "${c_rgs[$i]}"; done \
      | fzf --with-nth=1 --delimiter=$'\t' --prompt="AKS cluster > " --height=40% --reverse)"
    [[ -n "$selected" ]] || exit 1
    echo "$(echo "$selected" | awk -F'\t' '{print $1}')|$(echo "$selected" | awk -F'\t' '{print $2}')"
  else
    echo "Select AKS cluster:" >&2
    for i in "${!c_names[@]}"; do printf "%2d) %s (RG: %s)\n" "$((i+1))" "${c_names[$i]}" "${c_rgs[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#c_names[@]} )) && { echo "${c_names[$((n-1))]}|${c_rgs[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

list_ns() { $KUBECTL --context "$KUBE_CTX" get ns -o custom-columns=NAME:.metadata.name --no-headers; }

pick_ns() {
  if has_fzf; then
    list_ns | fzf --prompt="AKS namespace > " --height=40% --reverse
  else
    local items=()
    while IFS= read -r line; do [[ -n "$line" ]] && items+=("$line"); done <<EOF
$(list_ns)
EOF
    ((${#items[@]})) || die "No namespaces found."
    echo "Select a namespace:" >&2
    for i in "${!items[@]}"; do printf "%2d) %s\n" "$((i+1))" "${items[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#items[@]} )) && { echo "${items[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

# ---------- Argument handling ----------
if [[ "${1:-}" == "--exec" ]]; then
  ATTACH_MODE="exec"
  shift
elif [[ "${1:-}" == "--attach" ]]; then
  ATTACH_MODE="attach"
  shift
fi

# ---------- Handle special commands ----------
if [[ "${1:-}" == "--list-orphaned" || "${1:-}" == "--list" || "${1:-}" == "-l" ]]; then
  list_orphaned_pods "${2:-}"
  exit 0
fi

if [[ "${1:-}" == "--cleanup-all" || "${1:-}" == "--cleanup" ]]; then
  cleanup_all_orphaned "${2:-}"
  exit 0
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<HELP
Usage: aksc [OPTIONS]

AKS Console - Interactively connect to Rails console in Azure Kubernetes Service

OPTIONS:
  (no args)                Run normally - pick subscription, cluster, namespace, and start console
  --list, -l [USER]        List all orphaned Rails console pods (default: current user)
  --cleanup-all [USER]     Delete all orphaned Rails console pods (default: current user)
  --exec                   Use exec mode (starts a new console process)
  --attach                 Use attach mode (default)
  --help, -h               Show this help message

ENVIRONMENT:
  KEEP_POD=1               Keep pod on failure (for debugging)
  AKSC_ATTACH_MODE=exec    Force exec mode without passing --exec

EXAMPLES:
  aksc                     # Normal interactive mode
  aksc --exec              # Use exec mode (helpful if attach shows no prompt)
  aksc --list              # List your orphaned pods
  aksc --list john         # List john's orphaned pods
  aksc --cleanup-all       # Delete all your orphaned pods
  KEEP_POD=1 aksc          # Run but keep pod if it fails
  AKSC_ATTACH_MODE=exec aksc # Use exec mode via env var

HELP
  exit 0
fi

# ---------- Flow ----------
# If az isn't logged in, this will fail fast with a readable error.
az account show >/dev/null 2>&1 || die "Not logged into Azure CLI. Run: az login (MFA may be required)."

SUB_ID="$(pick_subscription)"

CLUSTER_INFO="$(pick_aks_cluster "$SUB_ID")"
CLUSTER_NAME="${CLUSTER_INFO%%|*}"
CLUSTER_RG="${CLUSTER_INFO##*|}"

# Unique kube context name per subscription+cluster
KUBE_CTX="aksc-${SUB_ID:0:8}-${CLUSTER_NAME}"

echo "Getting AKS credentials for $CLUSTER_NAME (subscription $SUB_ID)..." >&2
if ! CREDS_ERR="$(az aks get-credentials \
    --subscription "$SUB_ID" \
    --resource-group "$CLUSTER_RG" \
    --name "$CLUSTER_NAME" \
    --overwrite-existing \
    --context "$KUBE_CTX" \
    2>&1 >/dev/null)"; then
  echo "Error: Failed to get AKS credentials." >&2
  echo "Azure says:" >&2
  echo "$CREDS_ERR" >&2
  exit 1
fi

# ---------- Namespace ----------
NAMESPACE="$(pick_ns)"
$KUBECTL --context "$KUBE_CTX" get ns "$NAMESPACE" >/dev/null 2>&1 || die "Namespace '$NAMESPACE' not found."

# ---------- Detect image ----------
IMG=""
dep_imgs=()
while IFS= read -r line; do
  [[ -n "$line" ]] && dep_imgs+=("$line")
done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" get deploy \
  -o jsonpath='{range .items[*]}{range .spec.template.spec.containers[*]}{.image}{"\n"}{end}{end}' 2>/dev/null \
  | sed '/^\s*$/d' | sort -u || true)
EOF

((${#dep_imgs[@]})) || die "Could not detect an image in namespace '$NAMESPACE' (no deployments?)"

for i in "${dep_imgs[@]}"; do [[ "$i" == *".azurecr.io/"* ]] && { IMG="$i"; break; }; done
[[ -z "$IMG" ]] && IMG="${dep_imgs[0]}"

# ---------- Detect ConfigMap ----------
CM=""
if $KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" get cm "${NAMESPACE}-config" >/dev/null 2>&1; then
  CM="${NAMESPACE}-config"
else
  cms=()
  while IFS= read -r line; do [[ -n "$line" ]] && cms+=("$line"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" get cm -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null | grep -Ei 'config|env' || true)
EOF

  if ((${#cms[@]}==1)); then
    CM="${cms[0]}"
  elif ((${#cms[@]}>1)); then
    if has_fzf; then
      CM="$(printf "%s\n" "${cms[@]}" | fzf --prompt="ConfigMap > " --height=40% --reverse)"
    else
      echo "Select ConfigMap:" >&2
      for i in "${!cms[@]}"; do printf "%2d) %s\n" "$((i+1))" "${cms[$i]}" >&2; done
      read -rp "> " m
      [[ "$m" =~ ^[0-9]+$ ]] && (( m>=1 && m<=${#cms[@]} )) && CM="${cms[$((m-1))]}"
    fi
  fi
fi

# ---------- Copy scheduling from a real running app pod ----------
IMG_NO_DIGEST="${IMG%@*}"
REPO="${IMG_NO_DIGEST%:*}"

REF_POD="$(
  $KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" get pods \
    -o jsonpath='{range .items[?(@.status.phase=="Running")]}{.metadata.name}{"\t"}{range .spec.containers[*]}{.image}{" "}{end}{"\n"}{end}' \
  | awk -v repo="$REPO" '$0 ~ repo {print $1; exit}'
)"
if [[ -z "$REF_POD" ]]; then
  REF_POD="$(
    $KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" get pods \
      -o jsonpath='{range .items[?(@.status.phase=="Running")]}{.metadata.name}{"\t"}{.metadata.ownerReferences[0].kind}{"\n"}{end}' \
    | awk '$2=="ReplicaSet"{print $1; exit}'
  )"
fi
[[ -n "$REF_POD" ]] || die "No suitable Running pod found in $NAMESPACE to copy scheduling from."

REF_JSON="$($KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" get pod "$REF_POD" -o json)"

SVC_ACCOUNT="$(printf '%s' "$REF_JSON" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("spec",{}).get("serviceAccountName","default"))')"
NODESELECTOR_JSON="$(printf '%s' "$REF_JSON" | python3 -c 'import sys,json; d=json.load(sys.stdin); import json as j; print(j.dumps(d.get("spec",{}).get("nodeSelector") or {}))')"
TOLERATIONS_JSON="$(printf '%s' "$REF_JSON" | python3 -c 'import sys,json; d=json.load(sys.stdin); import json as j; print(j.dumps(d.get("spec",{}).get("tolerations") or []))')"
AFFINITY_JSON="$(printf '%s' "$REF_JSON" | python3 -c 'import sys,json; d=json.load(sys.stdin); import json as j; print(j.dumps(d.get("spec",{}).get("affinity") or {}))')"

# ---------- Pod name ----------
USER_NAME="$(id -un 2>/dev/null || whoami)"
TS="$(date +%s)"
POD="rails-console-${USER_NAME}-${TS}"

if [[ "$ATTACH_MODE" == "exec" ]]; then
  POD_COMMAND='["/cnb/lifecycle/launcher"]'
  POD_ARGS='["sleep","infinity"]'
else
  POD_COMMAND='["/cnb/lifecycle/launcher"]'
  POD_ARGS='["bundle","exec","rails","console"]'
fi

if [[ -n "${CM:-}" ]]; then
  ENVFROM=$(cat <<YML
      envFrom:
        - configMapRef:
            name: $CM
YML
)
else
  ENVFROM=""
fi

# ---------- Create pod ----------
cat <<EOF | $KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" apply -f - >/dev/null
apiVersion: v1
kind: Pod
metadata:
  name: $POD
  labels:
    app: rails-console
spec:
  restartPolicy: Never
  terminationGracePeriodSeconds: 0
  serviceAccountName: $SVC_ACCOUNT
  nodeSelector: $NODESELECTOR_JSON
  tolerations: $TOLERATIONS_JSON
  affinity: $AFFINITY_JSON
  containers:
    - name: rails-console
      image: $IMG
      command: $POD_COMMAND
      args: $POD_ARGS
$ENVFROM
      env:
        - name: NEW_RELIC_AGENT_ENABLED
          value: "false"
      stdin: true
      tty: true
EOF

echo
echo "Kube context: $KUBE_CTX"
echo "Namespace:    $NAMESPACE"
echo "Image:        $IMG"
echo "ConfigMap:    ${CM:-<none>}"
echo "Ref pod:      $REF_POD"
echo "Pod:          $POD"
echo

# ---------- Wait with crash detection ----------
echo "Waiting for pod to be Ready (watching for crash)..."
deadline=$(( $(date +%s) + 180 ))

while true; do
  phase="$($KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" get pod "$POD" -o jsonpath='{.status.phase}' 2>/dev/null || echo "Unknown")"

  if [[ "$phase" == "Running" ]]; then
    ready="$($KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" get pod "$POD" -o jsonpath='{range .status.conditions[?(@.type=="Ready")]}{.status}{end}' 2>/dev/null || true)"
    [[ "$ready" == "True" ]] && break
  fi

  if [[ "$phase" == "Failed" || "$phase" == "Succeeded" ]]; then
    SUCCESS=1
    echo "Pod phase became $phase before Ready." >&2
    print_pod_debug "$NAMESPACE" "$POD"
    exit 1
  fi

  if (( $(date +%s) > deadline )); then
    SUCCESS=1
    echo "Timed out waiting for pod to become Ready." >&2
    print_pod_debug "$NAMESPACE" "$POD"
    exit 1
  fi

  sleep 2
done

echo "Pod is Ready. Connecting to Rails console."
if [[ "$ATTACH_MODE" == "exec" ]]; then
  echo "Using exec mode (starts a new console process)."
  if ! $KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" exec -it "pod/$POD" -c rails-console -- /cnb/lifecycle/launcher bundle exec rails console; then
    SUCCESS=1
    echo "Exec failed." >&2
    print_pod_debug "$NAMESPACE" "$POD"
    exit 1
  fi
else
  echo "Using attach mode. If no prompt appears, re-run with --exec or AKSC_ATTACH_MODE=exec."
  if ! $KUBECTL --context "$KUBE_CTX" -n "$NAMESPACE" attach -it "pod/$POD" -c rails-console; then
    SUCCESS=1
    echo "Attach failed." >&2
    print_pod_debug "$NAMESPACE" "$POD"
    exit 1
  fi
fi

SUCCESS=0
